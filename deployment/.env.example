# Database Configuration
DATABASE_URL=postgresql://karyaradhane_user:your_secure_password@localhost/karyaradhane

# JWT Configuration
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_base64_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
APP_NAME=Karyaradhane
DEBUG=False
ALLOWED_ORIGINS=*

