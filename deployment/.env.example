# Database Configuration
DATABASE_URL=postgresql://karyaradhane_user:ChangeThisPassword123!@localhost/karyaradhane

# JWT Configuration
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_base64_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (optional - for assignee notifications and reply sync)
# Gmail: enable 2FA, create App Password at https://myaccount.google.com/apppasswords
# Set EMAIL_ENABLED=true and fill SMTP_* / IMAP_* below, then restart the API.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_FROM_NAME=Project Management
SMTP_USE_TLS=true
SMTP_USE_SSL=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
EMAIL_POLL_INTERVAL_SECONDS=60

# File uploads for comment images
UPLOAD_DIR=./uploads
